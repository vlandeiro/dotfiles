# Config syntax crash course
# ==========================
# # The config file consists of simple key-value pairs,
# # separated by equals signs.
# font-family = Iosevka
# window-padding-x = 2
#
# # Spacing around the equals sign does not matter.
# # All of these are identical:
# key=value
# key= value
# key =value
# key = value
#
# # Any line beginning with a # is a comment. It's not possible to put
# # a comment after a config option, since it would be interpreted as a
# # part of the value. For example, this will have a value of "#123abc":
# background = #123abc
#
# # Empty values are used to reset config keys to default.
# key =
#
# # Some config options have unique syntaxes for their value,
# # which is explained in the docs for that config option.
# # Just for example:
# resize-overlay-duration = 4s 200ms

# Theme - Clean and modern
theme = light:One Half Light,dark:One Half Dark

# Font - Clean monospace with ligatures
font-family = JetBrains Mono
font-size = 13

# Window appearance - Clean minimal look
window-padding-x = 10
window-padding-y = 10
window-decoration = true
macos-titlebar-style = tabs

# Transparency for modern look (optional)
background-opacity = 0.95
background-blur-radius = 20

# Colors - Ensure tmux colors work properly
term = xterm-256color

# Shell integration - Works great with oh-my-zsh
shell-integration = zsh
shell-integration-features = cursor,sudo,title

# Quick terminal (your guake setup)
keybind = global:ctrl+grave_accent=toggle_quick_terminal
quick-terminal-size = 50%,100%
quick-terminal-animation-duration = 0.2

# Smooth scrolling
mouse-scroll-multiplier = 3

# Copy/paste
copy-on-select = true
clipboard-trim-trailing-spaces = true

# Emacs-style split bindings
keybind = cmd+x>2=new_split:down
keybind = cmd+x>3=new_split:right
keybind = cmd+x>0=close_surface

# Emacs-style

# Navigate splits (using super/cmd to avoid conflicts)
keybind = super+left=goto_split:left
keybind = super+right=goto_split:right
keybind = super+up=goto_split:top
keybind = super+down=goto_split:bottom
